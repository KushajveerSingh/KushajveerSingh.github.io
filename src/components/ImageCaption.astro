---
import { Image, type LocalImageProps } from "astro:assets";

type Props = {
  src: LocalImageProps['src'];
  alt?: string;
  caption?: string;
}
let { src, alt, caption } = Astro.props;

alt = caption ?? alt; 
---

<figure>
  <center><Image class="temp" src={src} alt={alt} /></center>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  figcaption {
    margin-top: 1px !important;
    text-align: center;
    font-style: italic;
  }
</style>