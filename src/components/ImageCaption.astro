---
import { Image } from "astro:assets";
const { src, caption } = Astro.props;
---

<figure>
  <Image class="temp" src={src} alt={caption} />
  <figcaption>{caption}</figcaption>
</figure>

<style>
  figcaption {
    margin-top: 1px !important;
    text-align: center;
    font-style: italic;
  }
</style>